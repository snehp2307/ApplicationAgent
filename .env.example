# ============================================
# BULK AI JOB OUTREACH BOT - Configuration
# ============================================
# Copy this file to .env and fill in your values

# --- REQUIRED: Mistral AI API Key ---
# Get yours at: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# --- REQUIRED: Gmail Credentials ---
# Use your Gmail address
GMAIL_EMAIL=your.email@gmail.com

# Gmail App Password (NOT your regular password!)
# Generate at: https://myaccount.google.com/apppasswords
# Steps: Google Account > Security > 2-Step Verification > App Passwords
GMAIL_APP_PASSWORD=your_16_char_app_password

# --- REQUIRED: Resume Path ---
# LOCAL:  Use your full system path
#         RESUME_PATH=C:/Users/YourName/Documents/resume.pdf
# DOCKER: Put resume in ./resume folder, then use container path
#         RESUME_PATH=/app/resume/resume.pdf
RESUME_PATH=/app/resume/resume.pdf

# --- REQUIRED: Tavily API Key (for web search) ---
# Get yours FREE at: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# --- OPTIONAL: Batch Configuration ---
# BATCH_SIZE=50
# MIN_DELAY_BETWEEN_EMAILS=30
# MAX_DELAY_BETWEEN_EMAILS=120
# BATCH_DELAY_MINUTES=10
# TARGET_COMPANY_COUNT=150
